# ──────────────────────────────────────────────────────────────
# GoalBuilder — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
# Used by docker-compose automatically. Change the password in production.
DATABASE_URL=postgresql://goalbuilder:goalbuilder@localhost:5432/goalbuilder

# ── Stripe (required for the $3 paywall) ─────────────────────
# Create a $3 one-time product in your Stripe dashboard.
# Dashboard → Products → Add product → One time → $3.00 USD
# Then copy the Price ID (starts with price_)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ── Buy Me a Coffee ──────────────────────────────────────────
# Your BMC page URL. Shown in the download modal and PDF.
BMAC_URL=https://buymeacoffee.com/your-page

# ── Admin endpoint ────────────────────────────────────────────
# Protects GET /admin/stats and GET /admin/subscribers
# Pass as: curl -H "X-Admin-Key: your-key" http://localhost:8000/admin/stats
ADMIN_API_KEY=change-me-to-something-secure

# ── Mailchimp (optional) ──────────────────────────────────────
# If left blank, subscriber emails are stored in PostgreSQL only.
# Find your server prefix in Mailchimp → Account → API keys (e.g. "us21")
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_SERVER_PREFIX=

# ── App ───────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
